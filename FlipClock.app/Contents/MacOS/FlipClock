#!/bin/bash
# FlipClock launcher — runs the Electron app silently

# Hardcode the path to Node/npm (via NVM)
export PATH="/Users/ramneetsingh/.nvm/versions/node/v22.16.0/bin:/usr/local/bin:/opt/homebrew/bin:$PATH"

# Navigate to the project directory (relative to .app location)
APP_DIR="$(cd "$(dirname "$0")/../../.." && pwd)"
cd "$APP_DIR"

# Launch Electron in the background and detach
nohup npm start &>/dev/null &
